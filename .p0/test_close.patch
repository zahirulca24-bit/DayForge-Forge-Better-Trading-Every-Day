+    def test_transaction_log_exact_identity_excludes_other_overlapping_trade(self) -> None:
+        trade = {
+            **trade_payload(),
+            "order_id": "open-a",
+            "exchange_metadata": {
+                "order_link_id": "entry-link-a",
+                "management": {
+                    "initial_quantity": 1.0,
+                    "tp1_order_id": "close-a",
+                },
+            },
+        }
+        records = [
+            {
+                "symbol": "BTCUSDT",
+                "type": "Trade",
+                "direction": "Open Buy",
+                "qty": "1",
+                "filledPrice": "100",
+                "fee": "1",
+                "change": "-1",
+                "transactionTime": str(OPENED_MS + 1_000),
+                "orderId": "open-a",
+            },
+            {
+                "symbol": "BTCUSDT",
+                "type": "Trade",
+                "direction": "Open Buy",
+                "qty": "1",
+                "filledPrice": "100",
+                "fee": "2",
+                "change": "-2",
+                "transactionTime": str(OPENED_MS + 2_000),
+                "orderId": "open-b",
+            },
+            {
+                "symbol": "BTCUSDT",
+                "type": "Trade",
+                "direction": "Close Sell",
+                "qty": "1",
+                "filledPrice": "90",
+                "fee": "1",
+                "cashFlow": "-10",
+                "change": "-11",
+                "transactionTime": str(OPENED_MS + 60_000),
+                "orderId": "close-b",
+            },
+            {
+                "symbol": "BTCUSDT",
+                "type": "Trade",
+                "direction": "Close Sell",
+                "qty": "1",
+                "filledPrice": "110",
+                "fee": "1",
+                "cashFlow": "10",
+                "change": "9",
+                "transactionTime": str(OPENED_MS + 120_000),
+                "orderId": "close-a",
+            },
+        ]
+
+        result, error = aggregate_transaction_log_records(
+            trade, records, opened_ms=OPENED_MS, require_exact_identity=True
+        )
+
+        self.assertIsNone(error)
+        self.assertIsNotNone(result)
